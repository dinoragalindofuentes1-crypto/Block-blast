// Block Blast Game

// Main menu
function showMainMenu() {
    console.log('Welcome to Block Blast!');
    console.log('1. Classic');
    console.log('2. Beat Your World Record');
    console.log('3. Adventure');
    var choice = getUserInput();
    handleMenuChoice(choice);
}

// Handle menu choice
function handleMenuChoice(choice) {
    switch(choice) {
        case 1:
            startClassicMode();
            break;
        case 2:
            beatYourRecord();
            break;
        case 3:
            startAdventureMode();
            break;
        default:
            console.log('Invalid choice, please try again.');
            showMainMenu();
    }
}

