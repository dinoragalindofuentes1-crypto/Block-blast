<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Block Blast Game</title>
    <style>
        canvas {
            border: 1px solid black;
            display: block;
            margin: 0 auto;
        }
        #score {
            text-align: center;
            font-size: 24px;
        }
    </style>
</head>
<body>
    <h1>Block Blast Game</h1>
    <div id="score">Score: 0</div>
    <canvas id="gameCanvas" width="400" height="400"></canvas>
    <script>
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        const gridSize = 8;
        const tileSize = 50;
        const board = Array.from({ length: gridSize }, () => Array(gridSize).fill(0));
        let score = 0;
        let gameOver = false;

        function drawBoard() {
            for (let row = 0; row < gridSize; row++) {
                for (let col = 0; col < gridSize; col++) {
                    ctx.fillStyle = board[row][col] ? 'blue' : 'white';
                    ctx.fillRect(col * tileSize, row * tileSize, tileSize, tileSize);
                    ctx.strokeRect(col * tileSize, row * tileSize, tileSize, tileSize);
                }
            }
            document.getElementById('score').innerText = `Score: ${score}`;
        }

        function checkForLineClear() {
            for (let row = 0; row < gridSize; row++) {
                const fullLine = board[row].every(cell => cell);
                if (fullLine) {
                    board.splice(row, 1);
                    board.unshift(Array(gridSize).fill(0));
                    score += 10;
                }
            }
        }

        function isGameOver() {
            return board[0].some(cell => cell);
        }

        function gameLoop() {
            if (gameOver) {
                alert('Game Over!');
                return;
            }
            drawBoard();
            checkForLineClear();
            gameOver = isGameOver();
            requestAnimationFrame(gameLoop);
        }

        canvas.addEventListener('click', (event) => {
            const rect = canvas.getBoundingClientRect();
            const x = Math.floor((event.clientX - rect.left) / tileSize);
            const y = Math.floor((event.clientY - rect.top) / tileSize);
            if (board[y][x] === 0) {
                board[y][x] = 1;
            }
        });

        gameLoop();
    </script>
</body>
</html>