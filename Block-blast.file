<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Block Blast Arcade</title>
    <link rel="stylesheet" href="styles.css">
    <script src="service-worker.js" defer></script>
</head>
<body>
    <header>
        <h1>Welcome to Block Blast Arcade!</h1>
    </header>
    <main>
        <div id="games-container">
            <!-- Placeholder for game slots -->
            <div class="game" id="game1">Game 1</div>
            <div class="game" id="game2">Game 2</div>
            <div class="game" id="game3">Game 3</div>
            <div class="game" id="game4">Game 4</div>
            <div class="game" id="game5">Game 5</div>
            <div class="game" id="game6">Game 6</div>
            <div class="game" id="game7">Game 7</div>
            <div class="game" id="game8">Game 8</div>
        </div>
        <button id="download-btn">Download Game for Offline Play</button>
        <progress id="progress" value="0" max="100"></progress>
    </main>
    <footer>
        <small>&copy; 2026 Block Blast Arcade</small>
    </footer>
    <script>
        // Javascript for download and progress bar
        document.getElementById('download-btn').addEventListener('click', function() {
            let progress = document.getElementById('progress');
            progress.value = 0;
            // Simulate download
            let interval = setInterval(() => {
                if (progress.value < 100) {
                    progress.value += 10;
                } else {
                    clearInterval(interval);
                    alert("Download Complete!");
                }
            }, 100);
        });
    </script>
</body>
</html>
